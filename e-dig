# e-dig: The ultimate tool for high-quality audio sampling
#
# Project: https://github.com/galaxy-cli/e-dig

# --- USAGE ---
print_usage() {
    cat <<EOF
DESCRIPTION
  e-dig is a lightweight CLI tool for music producers and crate-diggers.
  It extracts high-quality audio samples with clean metadata (Channel, Date, Title)

USAGE
  e-dig [OPTION]

OPTION
  --help            Show this help message
  -v, --version     Show current yt-dlp version
  -p, --path [DIR]  Specify a directory to save the downloads
  --mpv             Immediately play the audio after downloading
  -i, --initialize  Install or update dependencies (yt-dlp, ffmpeg, & mpv)
  -u, --url         Triggers a safe prompt to paste your YouTube URL
  -b, --batch       Batch processses text file of YouTube URL

EXAMPLES
  e-dig -u                       Quickly download a sample to the current folder
  e-dig --path ~/Samples -u      Download a sample to a specific "Samples" folder
  e-dig --mpv --url              Download and play immediately to check quality
  e-dig -i                       Set up or update ffmpeg, mpv, and yt-dlp
  e-dig -p ./Drums -mpv -u       Download a drum break to a subfolder and play it
  e-dig --batch links.txt        Download every URL listed in a text file
EOF
}

# --- DEPENDENCIES ---
install_deps() {
    echo "Checking dependencies..."
    if ! command -v pipx >/dev/null 2>&1; then
        sudo apt update -qq && sudo apt install -y -qq pipx
        pipx ensurepath
    fi
    if ! command -v ffmpeg >/dev/null 2>&1 || ! command -v mpv >/dev/null 2>&1; then
        sudo apt update -qq && sudo apt install -y -qq ffmpeg mpv
    fi
    if pipx list | grep -q "yt-dlp"; then
        pipx upgrade yt-dlp
    else
        pipx install "yt-dlp[default]"
    fi
    echo "All dependencies ready"
}

# --- ARGUMENT PARSING ---
if [[ $# -eq 0 ]]; then
    echo "Try 'e-dig --help' for more information" >&2
    exit 1
fi

SAVE_PATH="."
PLAY_NOW=false
DOWNLOAD_URLS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help) print_usage; exit 0 ;;
        -v|--version) yt-dlp --version; exit 0 ;;
        -p|--path) SAVE_PATH="$2"; shift 2 ;;
        --mpv) PLAY_NOW=true; shift ;;
        -i|--initialize) install_deps; exit 0 ;;
        -u|--url)
            shift
            if [[ $# -eq 0 ]]; then
                echo -n "Paste YouTube URL and press Enter: "
                read -ra sample
                DOWNLOAD_URLS+=("$sample") 
            fi
            ;;
        -b|--batch)
            if [[ -f "$2" ]]; then
                while IFS= read -r line; do
                    [[ -n "$line" ]] && DOWNLOAD_URLS+=("$line")
                done < "$2"
                shift 2
            else
                echo "ERROR - File '$2' not found" >&2
                exit 1
            fi
            ;;
        *) 
            echo "Invalid option or argument '$1'" >&2
            echo "Try 'e-dig --help' for more information" >&2
            exit 1 
            ;;
    esac
done

# --- DOWNLOAD LOGIC ---
for url in "${DOWNLOAD_URLS[@]}"; do
    clean_url="${url%%&*}"
    echo "Digging..."
    
    FILENAME=$(yt-dlp -x \
        -P "$SAVE_PATH" \
        --audio-format flac \
        --audio-quality 0 \
        --newline \
        --no-warnings \
        --no-playlist \
        --output "%(title)s.%(ext)s" \
        --embed-metadata \
        --print "after_move:filepath" \
        "$clean_url")

    if [[ $? -eq 0 ]]; then
        FINAL_FILE=$(echo "$FILENAME" | tail -n 1)
        echo "$(basename "$FINAL_FILE") created"
        
        if $PLAY_NOW; then
            echo "Auditioning sample..."
            mpv --no-video "$FINAL_FILE"
        fi
    else
        echo "ERROR - Download failed" >&2
    fi
done

echo "--------------------------------"
echo "Session complete. Happy producing!"